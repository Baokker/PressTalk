# 讯飞实时语音转写 API
# 在 https://www.xfyun.cn/ 创建应用后获取
XFYUN_APPID=your_appid_here
XFYUN_API_KEY=your_api_key_here
XFYUN_API_SECRET=your_api_secret_here

# DeepSeek API（Phase 2 智能整理用）
# 在 https://platform.deepseek.com/ 获取
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# STT 后端选择: "xfyun" 或 "whisper"（本地）
STT_BACKEND=xfyun

# 本地 Whisper 模型（STT_BACKEND=whisper 时生效）
# 推荐 turbo（~1.6GB，中文质量好，速度快）；tiny/base/small/medium/large-v3 可选
WHISPER_MODEL=turbo
